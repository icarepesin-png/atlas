# Copier vers .env et remplir. Aucune cle n'est obligatoire pour le mode MVP (Yahoo Finance).

# Macro (gratuit: https://fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=

# Donnees marche premium (optionnel, requis pour scaler au-dela de ~1500 titres)
POLYGON_API_KEY=
FMP_API_KEY=
ALPHA_VANTAGE_API_KEY=

# Execution (Phase 2+, paper trading d'abord)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER=true

# Interactive Brokers (TWS / IB Gateway)
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=1

# Base de donnees (defaut: SQLite local, Postgres en production)
DATABASE_URL=sqlite:///atlas.db
# DATABASE_URL=postgresql+psycopg2://atlas:atlas@localhost:5432/atlas

# Notifications Telegram (token via @BotFather, puis: python -m atlas.monitoring.notify --setup)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Garde-fou: live trading desactive tant que ce flag n'est pas explicitement "I_UNDERSTAND_THE_RISKS"
LIVE_TRADING_ACK=
